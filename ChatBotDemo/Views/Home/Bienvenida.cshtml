@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div style="text-align:center;">

    <!-- Imagen -->
    <img src="~/images/logo1-1.png" alt="Bienvenida"
         style="
         width:220px;
         margin-bottom:20px;
         " />

    <!-- 🎯 Título -->
    <h1 style="color:#5A7D9A;">
        Bienvenido al Chatbot Médico
    </h1>

    <!-- 🧠 Descripción -->
    <p style="
        color:#6B8CA6;
        font-size:16px;
        max-width:500px;
        margin:auto;
    ">
        Este sistema te permite registrar pacientes, consultar información médica
        y realizar interacciones mediante un chatbot inteligente.
    </p>

    <br />

    <!-- 🚀 Acciones rápidas -->
    <div style="margin-top:20px;">

        <a href="/Home/RegistroPaciente" style="
            display:inline-block;
            margin:10px;
            padding:10px 20px;
            background:#7EC8E3;
            color:white;
            border-radius:8px;
            text-decoration:none;
        ">
            <img src="~/images/icon/agregar.png" style="width:16px;height:16px;" /> 
            Registro Paciente
        </a>

        <a href="/Home/Chat" style="
            display:inline-block;
            margin:10px;
            padding:10px 20px;
            background:#A7D7F9;
            color:#2F4F4F;
            border-radius:8px;
            text-decoration:none;
        ">
            <img src="~/images/icon/chat.png" style="width:16px;height:16px;" /> 
            Ir al Chat
        </a>

    </div>

</div>